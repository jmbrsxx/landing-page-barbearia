rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /barbers/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /services/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /barberSchedules/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /userProfiles/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.id;
      allow create: if request.auth != null && request.auth.uid == request.resource.id;
    }
  }
}
